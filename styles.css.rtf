\}\
\
/* Mobile Responsive */\
@media (max-width: 768px) \{\
    .container \{\
        flex-direction: column;\
    \}\
\
    .left-column \{\
        width: 100%;\
        padding: 30px;\
        border-right: none;\
        border-bottom: 1px solid #333;\
    \}\
\
    .right-column \{\
        width: 100%;\
        padding: 30px;\
    \}\
\
    .player-container iframe \{\
        width: 100%;\
        max-width: 350px;\
    \}\
\}\
